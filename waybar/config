  {
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "gtk-layer-shell": true,
    "spacing": 0,
    "height": 0,
    "margin-top": 0,
    "margin-bottom": 1,
    "margin-left": 5,
    "margin-right": 15,

    "modules-left": [
      "custom/applauncher",
      "sway/workspaces",
      "custom/mpris",
      "custom/mpris-prev",
      "custom/mpris-playpause",
      "custom/mpris-next"
    ],

    "modules-center": [
      "clock"
    ],

    "modules-right": [
      "bluetooth",
      "network",
      "pulseaudio",
      "battery",
      "custom/power"
    ],

    "custom/applauncher": {
      "format": "〇",
      "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y 15",
      "tooltip": false
    },

    "sway/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "tooltip": false
    },

    "clock": {
      "format": "{:%I:%M %p}",
      "format-alt": "{:%B %d %a}",
      "tooltip": false
    },
    
    "custom/mpris": {
      "exec": "~/.config/waybar/scripts/mpris.sh",
      "interval": 1,
      "tooltip": false,
      "escape": true
    },
    
    "custom/mpris-prev": {
      "format": "󰒮",
      "on-click": "playerctl previous",
      "tooltip": false
    },
    
    "custom/mpris-playpause": {
      "format": "󰏤",
      "on-click": "playerctl play-pause",
      "tooltip": false
    },
    
    "custom/mpris-next": {
      "format": "󰒭",
      "on-click": "playerctl next",
      "tooltip": false
    },
         
    "bluetooth": {
      "format": "󰂯",
      "format-connected": "󰂱 {device_alias}",
      "format-disabled": "󰂲",
      "format-off": "󰂲 Off",
      "tooltip": false,
      "on-click": "orbit toggle --tab bluetooth"
    },

    "network": {
      "format-wifi": "󰖩 {essid}",
      "format-ethernet": "󰈀 Connected",
      "format-disconnected": "󰖪 Disconnected",
      "format-off": "󰖪 Off",
      "interval": 5,
      "tooltip": false,
      "on-click": "orbit toggle --tab wifi"
    },

    "pulseaudio": {
      "scroll-step": 5,
      "max-volume": 150,
      "format": "{icon} {volume}%",
      "format-muted": "󰝟 Muted",
      "format-icons": {
        "default": ["󰕿", "󰖀", "󰕾"]
      },
      "tooltip": false,
      "on-click": "pavucontrol"
    },

    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "󰂄 {capacity}%",
      "format-plugged": "󰂄{capacity}%",
      "format-alt": "{icon} {time}",
      "format-full": "󱈑 {capacity}%",
      "format-icons": [
        "󱊡",
        "󱊢",
        "󱊣"
      ]
    },
    
    "custom/power": {
      "format": "⏻",
      "tooltip": false,
      "on-click": "~/.config/waybar/scripts/power.sh"
    }, 

    
    
   }
